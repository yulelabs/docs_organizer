# API
PORT=3000
NODE_ENV=development
DATABASE_URL=postgresql://docs:docs@localhost:5432/docs_organizer
CORS_ORIGIN=http://localhost:5173
PUBLIC_APP_URL=http://localhost:5173
PUBLIC_API_URL=http://localhost:3000
SESSION_SECRET=dev-session-secret-change-me
SESSION_DAYS=30

# OAuth (optional — leave blank to hide social buttons)
# Callback URLs: {PUBLIC_API_URL}/api/auth/oauth/{google|facebook|github}/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Storage: "local" for filesystem, "r2" for Cloudflare R2
STORAGE_DRIVER=local
LOCAL_STORAGE_DIR=./data/uploads

# Cloudflare R2 (when STORAGE_DRIVER=r2)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=docs-organizer
R2_PUBLIC_URL=

# OCR
OCR_LANG=por+eng
OCR_TMP_DIR=./data/ocr-tmp
