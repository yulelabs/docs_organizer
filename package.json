{
  "name": "docs-organizer",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspaces --if-present",
    "dev:api": "npm run dev -w @docs-organizer/api",
    "dev:web": "npm run dev -w @docs-organizer/web",
    "build": "npm run build --workspaces --if-present",
    "build:api": "npm run build -w @docs-organizer/api",
    "build:web": "npm run build -w @docs-organizer/web",
    "start:api": "npm run start -w @docs-organizer/api",
    "db:migrate": "npm run db:migrate -w @docs-organizer/api",
    "test": "npm run test -w @docs-organizer/api",
    "deploy:provision": "bash ./scripts/provision-and-deploy.sh",
    "typecheck": "npm run typecheck --workspaces --if-present"
  },
  "engines": {
    "node": ">=22"
  }
}
